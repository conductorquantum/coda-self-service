FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends openvpn iproute2 curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app
COPY pyproject.toml LICENSE README.md ./
COPY src/ src/
COPY tests/ tests/

RUN uv sync --frozen --no-install-workspace 2>/dev/null || uv sync

ENTRYPOINT ["uv", "run", "pytest"]
CMD ["tests/test_self_service_smoketest.py", "-v", "-m", "smoketest"]
